{
  "name": "emmanpbarrameda/laravel-scheduled-maintenance",
  "description": "Modern Laravel scheduled maintenance windows with notices, bypass mode, redirects, and custom maintenance responses.",
  "keywords": [
    "scheduled-maintenance",
    "laravel",
    "laravel-scheduled-maintenance",
    "laravel-maintenance",
    "maintenance-mode"
  ],
  "homepage": "https://github.com/emmanpbarrameda/laravel-scheduled-maintenance",
  "license": "MIT",
  "authors": [
    {
      "name": "James Burrow",
      "email": "james.burrow@churchportal.com",
      "role": "Original Author"
    },
    {
      "name": "Emman P. Barrameda",
      "role": "Maintainer"
    }
  ],
  "require": {
    "php": "^8.1",
    "illuminate/contracts": "^10.0|^11.0|^12.0",
    "illuminate/database": "^10.0|^11.0|^12.0",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "spatie/laravel-package-tools": "^1.16"
  },
  "require-dev": {
    "larastan/larastan": "^3.0",
    "nunomaduro/collision": "^7.0|^8.0|^9.0",
    "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
    "pestphp/pest": "^2.0|^3.0",
    "pestphp/pest-plugin-laravel": "^2.0|^3.0",
    "phpunit/phpunit": "^10.0|^11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "Emmanpbarrameda\\ScheduledMaintenance\\": "src/",
      "Emmanpbarrameda\\ScheduledMaintenance\\Database\\Factories\\": "database/factories/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Emmanpbarrameda\\ScheduledMaintenance\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Emmanpbarrameda\\ScheduledMaintenance\\ScheduledMaintenanceServiceProvider"
      ],
      "aliases": {
        "ScheduledMaintenance": "Emmanpbarrameda\\ScheduledMaintenance\\ScheduledMaintenanceFacade"
      }
    }
  },
  "scripts": {
    "analyse": "vendor/bin/phpstan analyse",
    "test": "vendor/bin/pest",
    "test-coverage": "vendor/bin/pest --coverage"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
